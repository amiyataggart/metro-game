# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# cloudflare / opennext build output
/.open-next/
/.wrangler/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

public/stats/*

# Local data backups
*.original.json

# QA render output (screenshots + reports)
/qa/

# Archived / deprecated build tooling (kept on disk as prior art, not tracked).
# See PARALLEL-RIBBONS-BRIEF.md for what lives here and why it was retired.
/archive/
# build-ribbons dev backups / A-B outputs (routes.preribbons.json IS tracked)
/src/app/(game)/london/data/*.baked.json
/src/app/(game)/london/data/features.preribbons.json
